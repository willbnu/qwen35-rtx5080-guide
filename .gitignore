# ============================================================
# qwen35-rtx5080-guide — .gitignore
# ============================================================

# --- Models (multi-gigabyte, never commit) ---
models/
*.gguf
*.safetensors
*.bin
*.pt
*.pth

# --- llama.cpp source tree (use official releases) ---
llama.cpp/
llama-bin/
*.exe
*.dll
*.so
*.dylib

# --- Python environments ---
venv/
venv_vllm/
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# --- Node.js ---
node_modules/

# --- Logs ---
logs/
*.log

# --- Archive (old superseded scripts) ---
archive/

# --- Sensitive / OS-specific ---
.env
.env.*
*.secret
Thumbs.db
.DS_Store
desktop.ini

# --- Images ---
*.png
*.jpg
*.jpeg
test_images/

# --- Stray artifacts ---
nul
*.tmp
*.bak
*.swp
*.swo
SOCIAL_POSTS.md
TERMINAL_BANNER*.txt
TERMINAL_OUTPUT.md
BENCHMARK_VISUAL.md
SCREENSHOT_GUIDE.md

# --- Debug/test scripts ---
launch_*.ps1
test_*.ps1
start_*_test.bat

# --- IDE ---
.idea/
.vscode/
*.code-workspace
.vs/

# --- Raw benchmark JSON ---
benchmark_*.json
results/benchmark_*.json
test_results/
results/test_results_*.json

# --- Misc large downloads ---
*.zip
llama*.zip

# --- Python cache ---
.ruff_cache/
__pycache__/
*.pyc
*.pyo

# --- AI tool configs (personal) ---
opencode.json
.claude*.json
.config/
.local/

# --- Auto Claude ---
.auto-claude/
.auto-claude-security.json
.auto-claude-status
.claude_settings.json
.worktrees/
.security-key
logs/security/
video/
