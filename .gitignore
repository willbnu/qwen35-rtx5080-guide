# ============================================================
# qwen35-rtx5080-guide — .gitignore
# ============================================================

# --- Models (multi-gigabyte, never commit) ---
models/
*.gguf
*.safetensors
*.bin
*.pt
*.pth

# --- llama.cpp source tree (use official releases) ---
llama.cpp/
llama-bin/
*.exe
*.dll
*.zip
*.so
*.dylib

# --- Python environments ---
venv/
venv_vllm/
.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# --- Logs (contain full absolute paths, no value for others) ---
logs/
*.log


# --- Sensitive / OS-specific ---
.env
.env.*
*.secret
Thumbs.db
.DS_Store
desktop.ini


# --- Sensitive / OS-specific ---
.env
.env.*
*.secret
Thumbs.db
.DS_Store
desktop.ini

# --- Images ---
*.png
*.jpg
*.jpeg
test_images/

# --- Stray artifacts ---
nul
*.tmp
*.bak
*.swp
*.swo
SOCIAL_POSTS.md
TERMINAL_BANNER*.txt
TERMINAL_OUTPUT.md
BENCHMARK_VISUAL.md
SCREENSHOT_GUIDE.md

# --- Debug/test scripts (created during benchmarking sessions) ---
launch_*.ps1
test_*.ps1
start_*_test.bat

# --- IDE ---
.idea/
.vscode/
*.code-workspace

# --- Raw benchmark JSON (contain absolute paths; BENCHMARK_RESULTS.md is the clean summary) ---
benchmark_*.json
results/benchmark_*.json
test_results/
results/test_results_*.json

# --- Node modules ---
node_modules/

# --- Misc large downloads ---
*.zip
llama*.zip

# Auto Claude data directory
.auto-claude/
