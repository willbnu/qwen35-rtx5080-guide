{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "local-qwen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Qwen (RTX 5080)",
      "options": {
        "baseURL": "http://localhost:8002/v1",
        "apiKey": "sk-no-key-required"
      },
      "models": {
        "qwen35-35b": {
          "name": "Qwen3.5-35B-A3B (Best Quality)",
          "description": "MoE model, 120 t/s gen, 400+ t/s prompt, 32K context (16GB VRAM limit), vision enabled",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "local-qwen-vision": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Qwen Vision (RTX 5080)",
      "options": {
        "baseURL": "http://localhost:8002/v1",
        "apiKey": "sk-no-key-required"
      },
      "models": {
        "qwen25-vl-9b": {
          "name": "Qwen2.5-VL-9B (Fast Vision)",
          "description": "97 t/s, 256K context, optimized for vision",
          "limit": {
            "context": 262144,
            "output": 8192
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "local-qwen-quality": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Qwen Quality (RTX 5080)",
      "options": {
        "baseURL": "http://localhost:8004/v1",
        "apiKey": "sk-no-key-required"
      },
      "models": {
        "qwen25-vl-27b": {
          "name": "Qwen2.5-VL-27B (Quality)",
          "description": "46 t/s, 96K context, best reasoning quality",
          "limit": {
            "context": 98304,
            "output": 8192
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "zai-glm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Z.AI Coding Plan",
      "options": {
        "baseURL": "https://open.bigmodel.cn/api/coding/paas/v4"
      },
      "models": {
        "glm-5": {
          "name": "GLM 5 (Coding Plan)",
          "limit": {
            "context": 200000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "model": "local-qwen-vision/qwen25-vl-9b",
  "small_model": "local-qwen-vision/qwen25-vl-9b",
  "permission": {
    "read": {
      ".env": "allow",
      ".env.*": "allow",
      ".env-*": "allow"
    },
    "external_directory": "allow",
    "bash": {
      "git push": "allow",
      "git push *": "allow",
      "npm *": "allow",
      "pnpm *": "allow",
      "bun *": "allow"
    }
  },
  "autoupdate": true
}